{
  "name": "robin-syntax",
  "displayName": "Robin (Power Automate Desktop) Syntax",
  "description": "Syntax highlighting and folding for Power Automate Desktop (.robin or .pad) files",
  "version": "0.0.1",
  "publisher": "HairyDrumroll",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "robin",
        "aliases": ["Robin", "robin", "PAD", "pad", "Power Automate Desktop", "powerautomate"],
        "extensions": [".robin", ".pad", ".powerautomate"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "robin",
        "scopeName": "source.robin",
        "path": "./syntaxes/robin.tmLanguage.json"
      }
    ]
  }
}